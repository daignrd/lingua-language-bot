# Bot identity & target language (REQUIRED)
BOT_NAME=Lingua
TARGET_LANGUAGE=Italian
USER_LOCATION=Rome
LEVEL_SYSTEM=CEFR B1

# Daily morning briefing schedule
# MORNING_HOUR is local hour (0-23) in your target timezone
# MORNING_TIMEZONE_OFFSET is your UTC offset in hours (e.g. 1 for CET, 9 for JST, -5 for EST)
MORNING_HOUR=9
MORNING_TIMEZONE_OFFSET=1

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ALLOWED_USER_ID=your_telegram_user_id_here

# LLM (OpenRouter for chat)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Vision (Gemini)
GEMINI_API_KEY=your_gemini_api_key_here

# Voice — STT (Groq Whisper) and TTS (ElevenLabs)
GROQ_API_KEY=your_groq_api_key_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=pFZP5JQG7iQjIQuC4Bku

# Database (Supabase + pgvector)
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here
